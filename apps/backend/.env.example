PORT=4000

# === CORS CONFIGURATION ===
# FRONTEND_ORIGIN: Comma-separated list of allowed frontend origins for CORS
# Required for production! Must include all frontend deployment URLs.
# CRITICAL: Add NEW Vercel domain IMMEDIATELY after each Vercel redeploy
# Every time Vercel rebuilds your frontend, it gets a new domain (e.g., gwbas3hda)
# You must add it here and redeploy Render backend.
# Format: url1,url2,url3 (no spaces around commas)
#
# CURRENT DOMAINS (as of 2026-05-05):
#   Development: http://localhost:3000,http://localhost:3001
#   Old preview: https://zynetro-application-frontend-nrqy.vercel.app
#   Old production: https://zynetro-application-frontend-9ren-qtadat834.vercel.app
#   CURRENT production: https://zynetro-application-frontend-gwbas3hda.vercel.app
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001
# Wildcard pattern for all Vercel preview deployments - no more manual domain updates!
FRONTEND_ORIGIN_PATTERNS=https://zynetro-application-frontend-*.vercel.app

# Optional wildcard patterns (comma-separated) for preview/preview deployments.
# FRONTEND_ORIGIN_PATTERNS: Regex patterns to allow multiple preview deployments dynamically.
# Example: FRONTEND_ORIGIN_PATTERNS=https://zynetro-application-*.vercel.app
FRONTEND_ORIGIN_PATTERNS=
MONGODB_URI=mongodb://127.0.0.1:27017/zynetra
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
LEAD_NOTIFICATION_TO=yourgmail@gmail.com
JWT_SECRET=your-strong-jwt-secret
